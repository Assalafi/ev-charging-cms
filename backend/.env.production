# ======================
# Environment
# ======================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
BASE_URL=https://evcharging.eride.ng
API_PREFIX=/api

# ======================
# Database
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ev_charging_prod
DB_USER=assalafi
DB_PASSWORD=Assalafi@139
DB_DIALECT=postgres
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ======================
# Authentication
# ======================
JWT_SECRET=your-secure-jwt-secret-key-here
JWT_EXPIRATION=24h
COOKIE_SECRET=your-secure-cookie-secret-key

# ======================
# CORS
# ======================
CORS_ORIGIN=https://evcharging.eride.ng
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true
CORS_PREFLIGHT_CONTINUE=false

# ======================
# OCPP
# ======================
OCPP_SERVER_PORT=8081
OCPP_SERVER_PATH=/ocpp
OCPP_SERVER_HOST=0.0.0.0
OCPP_SUPPORTED_VERSIONS=ocpp1.6,ocpp1.5,ocpp2.0.1

# ======================
# MQTT
# ======================
MQTT_ENABLED=true
MQTT_CLIENT_ID=ev-cms-backend
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_HOST=evcharging.eride.ng
MQTT_PORT=9883  # Changed from 8883 to 9883
MQTT_PROTOCOL=mqtts
MQTT_USERNAME=ev_cms_admin
MQTT_PASSWORD=Assalafi@139
MQTT_BROKER=mqtt://localhost:1883

# ======================
# Rate Limiting
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=99999999999999
RATE_LIMIT_MESSAGE="Too many requests, please try again later"

# ======================
# File Storage
# ======================
UPLOADS_DIR=/var/www/uploads
FIRMWARE_DIR=/var/www/uploads/firmware
LOGS_DIR=/var/log/evcharging
MAX_FILE_SIZE=50MB

# ======================
# Logging
# ======================
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_ROTATION_INTERVAL=1d
LOG_MAX_FILES=30d

# ======================
# Monitoring
# ======================
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=false
METRICS_PORT=9090

REACT_APP_API_URL=https://evcharging.eride.ng/api
REACT_APP_MQTT_WS_URL=wss://evcharging.eride.ng/mqtt